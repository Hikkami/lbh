---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Pobranie wszystkich wpisów z kolekcji 'portfolio'
const projects = await getCollection('portfolio');
---

<Layout 
  title="Nasze Portfolio | StudioDev" 
  description="Przejrzyj nasze najlepsze projekty, aplikacje internetowe i wdrożenia."
>
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Nagłówek sekcji -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white">
          Portfolio
        </h1>
        <p class="mt-4 text-slate-600 dark:text-zinc-400">
          Odkryj wybrane projekty, które zrealizowaliśmy dla naszych klientów. Dbamy o wydajność, dostępność i nowoczesny design.
        </p>
      </div>

      <!-- Siatka projektów -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <article class="group overflow-hidden rounded-2xl border border-slate-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 shadow-sm flex flex-col h-full transition hover:shadow-md">
            
            {/* Zdjęcie projektu */}
            <div class="aspect-video w-full overflow-hidden bg-slate-100 dark:bg-zinc-800">
              {project.data.image && (
                <img 
                  src={project.data.image} 
                  alt={project.data.title} 
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition duration-300"
                />
              )}
            </div>

            {/* Dane projektu */}
            <div class="p-6 flex flex-col flex-grow">
              <span class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider">
                {project.data.category}
              </span>
              <h2 class="text-xl font-bold text-slate-900 dark:text-white mt-2 mb-2">
                {project.data.title}
              </h2>
              <p class="text-slate-600 dark:text-zinc-400 text-sm mb-6 flex-grow line-clamp-3">
                {project.data.description}
              </p>
              
              {/* Link do dynamicznej podstrony na podstawie sluga */}
              <a 
                href={`/portfolio/${project.slug}/`} 
                class="text-sm font-semibold text-slate-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 inline-flex items-center gap-1 transition-colors"
              >
                Zobacz szczegóły <span>&rarr;</span>
              </a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>
</Layout>