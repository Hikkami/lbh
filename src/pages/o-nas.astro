---
import Layout from '../layouts/Layout.astro';

const stats = [
  { value: '5+', label: 'Lat doświadczenia' },
  { value: '80+', label: 'Zrealizowanych projektów' },
  { value: '98%', label: 'Zadowolonych klientów' },
];

const values = [
  { title: 'Jakość kodu', desc: 'Tworzymy czysty, semantyczny kod zgodny z najnowszymi standardami, co ułatwia dalszy rozwój projektu.' },
  { title: 'Terminowość', desc: 'Szanujemy Twój czas. Każdy etap prac realizujemy zgodnie z wcześniej ustalonym harmonogramem.' },
  { title: 'Partnerstwo', desc: 'Nie jesteśmy tylko wykonawcami. Słuchamy Twoich potrzeb i doradzamy optymalne rozwiązania biznesowe.' },
];
---

<Layout title="O nas | StudioDev" description="Poznaj nasz zespół, wartości i dowiedz się, jak pomagamy firmom rosnąć w sieci.">
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Nagłówek sekcji -->
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-5xl">
          Kim jesteśmy?
        </h1>
        <p class="mt-4 text-lg text-slate-600 dark:text-zinc-400">
          Jesteśmy zespołem pasjonatów technologii, którzy pomagają markom zaistnieć i rozwijać się w świecie cyfrowym.
        </p>
      </div>

      <!-- Treść o firmie -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
        <div class="space-y-6 text-slate-600 dark:text-zinc-400">
          <p>
            Nasza przygoda rozpoczęła się z chęci tworzenia rozwiązań internetowych pozbawionych zbędnego balastu technologicznego. Koncentrujemy się na budowaniu lekkich, szybkich i bezpiecznych witryn, które realnie wspierają cele naszych partnerów biznesowych.
          </p>
          <p>
            Wierzymy, że dobrze zaprojektowana strona to nie tylko kwestia estetyki, ale przede wszystkim intuicyjnej nawigacji, szybkości działania i skuteczności w pozyskiwaniu klientów.
          </p>
        </div>
        
        <!-- Sekcja Statystyk -->
        <div class="grid grid-cols-3 gap-6 bg-white dark:bg-zinc-900 p-8 rounded-2xl border border-slate-200 dark:border-zinc-800 shadow-sm">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="text-3xl sm:text-4xl font-extrabold text-blue-600 dark:text-blue-400">{stat.value}</div>
              <div class="text-xs sm:text-sm text-slate-500 dark:text-zinc-400 mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Nasze wartości -->
      <div>
        <h2 class="text-2xl font-bold text-center text-slate-900 dark:text-white mb-12">Nasze wartości</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {values.map((value) => (
            <div class="bg-slate-100/50 dark:bg-zinc-900/30 p-6 rounded-xl border border-slate-200/60 dark:border-zinc-800/60">
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">{value.title}</h3>
              <p class="text-sm text-slate-600 dark:text-zinc-400 leading-relaxed">{value.desc}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</Layout>