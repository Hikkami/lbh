    <p class="text-sm text-slate-500 dark:text-zinc-400">
      &copy; {currentYear} StudioDev. Wszelkie prawa zastrzeżone.
    </p>
    <div class="flex gap-6 text-sm text-slate-500 dark:text-zinc-400">
      <a href="#" class="hover:underline">Polityka prywatności</a>
      <a href="#" class="hover:underline">Regulamin</a>
